#This .gitignore file is specialized for Unity projects.

#It excludes temporary files, build artifacts, and local configuration.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/

#Memory dumps

MemoryCaptures/

#Asset Compute Cache

/AssetComputeCache/

#Gradle cache

.gradle/

#Exported Visual Studio solution support files

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

#Unity3D generated meta files

*.pidb.meta
*.pdb.meta
*.mdb.meta

#Unity3D Generated File On Crash Reports

sysinfo.txt

#Builds

*.apk
*.aab
*.unitypackage
*.app

#Crashlytics generated file

crashlytics-build.properties

#OS generated files

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db